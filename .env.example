# ===== Telegram Bot (BotFather) =====
TELEGRAM_BOT_TOKEN=
# Your personal Telegram user ID (numeric). Only this user can talk to the bot.
TELEGRAM_OWNER_ID=

# ===== Anthropic (Claude) =====
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ===== OpenAI (Whisper transcription + TTS reply) =====
OPENAI_API_KEY=
WHISPER_MODEL=whisper-1
# TTS model: tts-1 (fast/cheap) or tts-1-hd (higher quality)
TTS_MODEL=tts-1
# TTS voice: alloy, echo, fable, onyx, nova, shimmer
TTS_VOICE=nova

# ===== Google Calendar =====
# Path to credentials.json downloaded from Google Cloud Console
GOOGLE_CREDENTIALS_FILE=./data/google_credentials.json
# Path where the OAuth token will be stored after first auth
GOOGLE_TOKEN_FILE=./data/google_token.json
# Default calendar id ("primary" or a specific calendar id)
GOOGLE_DEFAULT_CALENDAR=primary

# ===== Userbot (Telethon) =====
# Get these from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Session name (will create <name>.session file)
TELETHON_SESSION_NAME=userbot
# Folder name for "other chats" (Hebrew: "שאר הצ'אטים")
USERBOT_OTHER_FOLDER=שאר הצ'אטים
# Time of day to run the daily scan (HH:MM, 24h, local time)
USERBOT_SCAN_TIME=03:00

# ===== General =====
# Timezone for reminders, scheduling, calendar
TIMEZONE=Asia/Jerusalem
# SQLite database path
DATABASE_PATH=./data/agent.db
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Bot persona/name (used in /help and friendly replies)
BOT_NAME=העוזר
